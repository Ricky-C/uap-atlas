# real release bundles from war.gov — large binary, not committed. Drop an
# extracted bundle in releases/<id>/ (with files/ + index.json) to ingest it.
# The committed synthetic fixture under ingest/fixtures/ is NOT ignored.
releases/

# NOTE: data/ is committed output (records.json, locations.json, cache/).
# Do NOT add a data/ ignore rule.
