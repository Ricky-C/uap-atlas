# dependencies
node_modules/

# build output
dist/
*.tsbuildinfo

# logs / debug output
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# env / secrets
.env
.env.*
!.env.example

# os / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# local-only Claude Code settings (project agents/commands/skills stay tracked)
.claude/settings.local.json

# Real war.gov release bundles — multi-GB binaries, never committed. The user
# downloads and extracts them locally (data/raw/release_NN/); ingest reads them
# from disk. The committed synthetic fixture under ingest/fixtures/ is NOT ignored.
releases/
data/raw/

# NOTE: data/ is otherwise committed output (records.json, locations.json, cache/).
# Only data/raw/ (the source bundles) is ignored — do NOT ignore data/ wholesale.

# Ephemeral batch-resume state for the Phase 2 enrichment pass. Holds a batch id
# that expires in ~29 days; the per-doc cache files under data/cache/ ARE committed.
data/cache/_batch-state.json
# Atomic-write temp siblings (writeJsonAtomic) — never commit a half-written file.
data/cache/*.tmp
.vercel
